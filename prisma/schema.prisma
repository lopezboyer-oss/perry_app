generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS (using String fields) ────────────────────────────────

// Role: ADMIN, ADMINISTRACION, SUPERVISOR, SUPERVISOR_SAFETY_LP, INGENIERO
// ActivityType: VISITA_CAMPO, COTIZACION, EJECUCION, PLANEACION, DISENO, CONSORCIO
// ActivityStatus: PENDIENTE, EN_PROGRESO, COMPLETADA, CANCELADA
// OpportunityStatus: EN_PROGRESO, COMPLETADA (derived from Activities, not stored)
// ReportSource: MANUAL, WHATSAPP_IMPORT
// TechnicianType: PROPIO, EXTERNO

// ─── MODELS ─────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  passwordHash      String
  role              String    @default("INGENIERO")
  isActive          Boolean   @default(true)
  isSafetyDesignado Boolean   @default(false)
  supervisorId      String?
  supervisor        User?     @relation("SupervisorTeam", fields: [supervisorId], references: [id])
  team              User[]    @relation("SupervisorTeam")
  baseCompanyId     String?
  baseCompany       Company?  @relation("UserBaseCompany", fields: [baseCompanyId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  companies     UserCompany[]
  activities    Activity[]
  dailyReports  DailyReport[]
  userSafetyAssignments WeekendUserSafetyAssignment[]
  invoiceReceipts InvoiceReceipt[]
}

model Client {
  id        String    @id @default(cuid())
  name      String
  code      String?   @unique
  status    String    @default("ACTIVO")
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  contacts      Contact[]
  activities    Activity[]
}

model Contact {
  id        String  @id @default(cuid())
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  position  String?
  email     String?
  phone     String?
  notes     String?

  activities    Activity[]
}

model DailyReport {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  reportDate DateTime
  rawText    String
  source     String   @default("MANUAL")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  activities Activity[]
}

model Activity {
  id              String       @id @default(cuid())
  dailyReportId   String?
  dailyReport     DailyReport? @relation(fields: [dailyReportId], references: [id])
  userId          String?
  user            User?        @relation(fields: [userId], references: [id])
  clientId        String?
  client          Client?      @relation(fields: [clientId], references: [id])
  contactId       String?
  contact         Contact?     @relation(fields: [contactId], references: [id])
  workOrderFolio  String?
  purchaseOrder   String?
  loto            Boolean      @default(false)
  date            DateTime
  type            String
  status          String       @default("PENDIENTE")
  projectArea     String?
  title           String
  result          String?
  nextStep        String?
  commitmentDate  DateTime?
  startTime       String?
  endTime         String?
  actualStartTime String?
  actualEndTime   String?
  durationMinutes Int?
  location        String?
  notes           String?
  weekendNotes    String?
  auditNotes      String?
  safetyAuditImage String?            // Base64 data URL of safety audit screenshot
  teraFolio        String?            // TERA folio number (e.g. BC-1234)
  consortiumCompany String?            // Target company when type=CONSORCIO (e.g. DROBOTS)
  companyId       String?
  company         Company?     @relation(fields: [companyId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  weekendTechAssignments    WeekendTechAssignment[]
  weekendSafetyAssignments  WeekendSafetyAssignment[]
  weekendVehicleAssignments WeekendVehicleAssignment[]
  weekendDriverAssignments  WeekendDriverAssignment[]
  weekendEquipAssignments   WeekendEquipAssignment[]
  weekendUserSafetyAssignments WeekendUserSafetyAssignment[]
}

// ─── PERSONAL OPERATIVO (FINDE) ─────────────────────────────────

model Technician {
  id            String      @id @default(cuid())
  name          String
  type          String      @default("PROPIO") // PROPIO | EXTERNO
  isCruzVerde   Boolean     @default(false)    // Acreditación Safety Designado
  isActive      Boolean     @default(true)
  contractorId  String?
  contractor    Contractor? @relation(fields: [contractorId], references: [id])
  baseCompanyId String?
  baseCompany   Company?    @relation(fields: [baseCompanyId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  weekendAssignments WeekendTechAssignment[]
}

model Contractor {
  id        String       @id @default(cuid())
  name      String       @unique
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  technicians Technician[]
}

model SafetyDedicado {
  id            String   @id @default(cuid())
  name          String
  isActive      Boolean  @default(true)
  baseCompanyId String?
  baseCompany   Company? @relation(fields: [baseCompanyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  weekendAssignments WeekendSafetyAssignment[]
}

model Vehicle {
  id            String   @id @default(cuid())
  name          String
  isAvailable   Boolean  @default(true)
  isActive      Boolean  @default(true)
  baseCompanyId String?
  baseCompany   Company? @relation(fields: [baseCompanyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  weekendAssignments WeekendVehicleAssignment[]
}

model Driver {
  id            String   @id @default(cuid())
  name          String
  isActive      Boolean  @default(true)
  baseCompanyId String?
  baseCompany   Company? @relation(fields: [baseCompanyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  weekendAssignments WeekendDriverAssignment[]
}

model ElevationEquip {
  id        String   @id @default(cuid())
  name      String
  ownership String   @default("PROPIO") // PROPIO | RENTADO
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weekendAssignments WeekendEquipAssignment[]
}

// ─── ASIGNACIONES FINDE ─────────────────────────────────────────

model WeekendTechAssignment {
  id           String     @id @default(cuid())
  activityId   String
  activity     Activity   @relation(fields: [activityId], references: [id], onDelete: Cascade)
  technicianId String
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  role         String     @default("TECNICO") // TECNICO | SAFETY_DESIGNADO
  weekendOf    String     // "YYYY-MM-DD" del sábado de ese fin de semana

  @@unique([activityId, technicianId, weekendOf])
}

model WeekendSafetyAssignment {
  id               String         @id @default(cuid())
  activityId       String
  activity         Activity       @relation(fields: [activityId], references: [id], onDelete: Cascade)
  safetyDedicadoId String
  safetyDedicado   SafetyDedicado @relation(fields: [safetyDedicadoId], references: [id], onDelete: Cascade)
  weekendOf        String

  @@unique([activityId, safetyDedicadoId, weekendOf])
}

model WeekendVehicleAssignment {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  weekendOf  String

  @@unique([activityId, vehicleId, weekendOf])
}

model WeekendDriverAssignment {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  driverId   String
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  weekendOf  String

  @@unique([activityId, driverId, weekendOf])
}

model WeekendEquipAssignment {
  id         String         @id @default(cuid())
  activityId String
  activity   Activity       @relation(fields: [activityId], references: [id], onDelete: Cascade)
  equipId    String
  equip      ElevationEquip @relation(fields: [equipId], references: [id], onDelete: Cascade)
  weekendOf  String

  @@unique([activityId, equipId, weekendOf])
}

model WeekendUserSafetyAssignment {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekendOf  String

  @@unique([activityId, userId, weekendOf])
}

// ─── DÍAS EXTRA (Plan ATC Finde) ────────────────────────────────

model ExtraPlanDay {
  id        String   @id @default(cuid())
  date      String   @unique   // "YYYY-MM-DD" del día extra
  weekendOf String              // "YYYY-MM-DD" del sábado asociado
  label     String?             // Etiqueta (ej: "Lunes Festivo")
  createdBy String?             // userId de quien lo creó
  createdAt DateTime @default(now())
}

// ─── COBRANZA ───────────────────────────────────────────────────

model InvoiceReceipt {
  id             String   @id @default(cuid())
  invoiceNumber  String   @unique   // Odoo invoice number (e.g. INV/2026/00149)
  folio          String?             // Odoo folio (e.g. S06254)
  po             String?             // P.O. number
  engineerName   String?             // Responsible engineer name (from Perry activity)
  confirmedById  String
  confirmedBy    User     @relation(fields: [confirmedById], references: [id])
  confirmedAt    DateTime @default(now())
  notes          String?
  createdAt      DateTime @default(now())
}

// ─── MULTIEMPRESA ───────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String   @unique              // "GRUPO CASEME"
  shortName   String?                       // "GC", "DR", "VF", "SP", "OI"
  odooId      Int      @unique              // 1, 2, 3, 4, 5
  folioPrefix String                        // "S", "V", "SA", "OS"
  folioFormat String                        // "S#####", "V###", etc.
  color       String?                       // Color hex for UI badges
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  userAccess      UserCompany[]
  baseUsers       User[]           @relation("UserBaseCompany")
  baseTechnicians Technician[]
  baseSafety      SafetyDedicado[]
  baseVehicles    Vehicle[]
  baseDrivers     Driver[]
  activities      Activity[]
}

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  isDefault Boolean  @default(false)   // empresa que se carga al login

  @@unique([userId, companyId])
}
